---
import { css, cx } from 'styled-system/css'
import { iconTile } from 'styled-system/recipes'
import { site } from '@/data/site'

interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<span
  class={cx(
    css({
      display: 'flex',
      alignItems: 'center',
      gap: '2.5',
      fontWeight: 'bold',
      fontSize: 'lg',
      letterSpacing: 'tight',
      color: 'fg.default',
    }),
    className
  )}
>
  <span
    class={cx(
      iconTile({ size: 'sm', tone: 'brand' }),
      css({ fontSize: 'sm', fontWeight: 'bold', fontFamily: 'mono' })
    )}
  >
    {'{}'}
  </span>
  {site.name}
</span>
