---
import { css } from 'styled-system/css'
import Container from '@/components/layout/Container.astro'
import BrandMark from '@/components/layout/BrandMark.astro'
import GithubIcon from '@/components/layout/GithubIcon.astro'
import { footerColumns } from '@/data/navigation'
import { links } from '@/data/site'
---

<footer
  class={css({
    borderTop: '1px solid',
    borderColor: 'border.subtle',
    bg: 'bg.canvas',
  })}
>
  <Container
    class={css({
      py: { base: '12', md: '16' },
      display: 'grid',
      gridTemplateColumns: { base: '1fr', sm: '1.5fr repeat(3, 1fr)' },
      gap: { base: '10', sm: '8' },
    })}
  >
    <div>
      <BrandMark />
      <a
        href={links.city.repo}
        aria-label="BmSDK on GitHub"
        class={css({
          mt: '5',
          display: 'inline-flex',
          color: 'fg.muted',
          transition: 'color 0.15s',
          _hover: { color: 'fg.default' },
        })}
      >
        <GithubIcon size={20} />
      </a>
    </div>

    {
      footerColumns.map((column) => (
        <div>
          <h4 class={css({ fontSize: 'sm', fontWeight: 'semibold', color: 'fg.default' })}>
            {column.title}
          </h4>
          <ul
            class={css({
              mt: '3',
              display: 'flex',
              flexDirection: 'column',
              gap: '2.5',
              listStyle: 'none',
            })}
          >
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class={css({
                    fontSize: 'sm',
                    color: 'fg.muted',
                    transition: 'color 0.15s',
                    _hover: { color: 'gh.link' },
                  })}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </Container>

  <div class={css({ borderTop: '1px solid', borderColor: 'border.subtle' })}>
    <Container
      class={css({
        py: '6',
        display: 'flex',
        flexWrap: 'wrap',
        gap: '3',
        justifyContent: 'space-between',
        alignItems: 'center',
        fontSize: 'xs',
        color: 'fg.subtle',
      })}
    >
      <span>Released under the MIT licence.</span>
      <span>Not affiliated with Warner Bros. Games or Rocksteady Studios.</span>
    </Container>
  </div>
</footer>
