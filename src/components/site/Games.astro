---
import { css, cx } from 'styled-system/css'
import { surface, iconTile } from 'styled-system/recipes'
import { Button } from '@/components/ui/button'
import { Download } from '@/lib/icons'
import Section from '@/components/layout/Section.astro'
import SectionHeading from '@/components/layout/SectionHeading.astro'
import GithubIcon from '@/components/layout/GithubIcon.astro'
import { games } from '@/data/games'
---

<Section id="download">
  <SectionHeading
    title="Built for <em>both games</em>"
    subtitle="BmSDK targets Batman: Arkham City and Arkham Knight, with the same scripting workflow for each. Pick your game and grab the latest release."
  />

  <div
    class={css({
      mt: '10',
      display: 'grid',
      gridTemplateColumns: { base: '1fr', md: '1fr 1fr' },
      gap: '5',
    })}
  >
    {
      games.map((game) => (
        <div
          class={cx(
            surface({ radius: 'xl' }),
            css({ display: 'flex', flexDirection: 'column', p: '6' })
          )}
        >
          <div class={iconTile({ size: 'lg', tone: 'outline' })}>
            <game.icon size={22} />
          </div>

          <h3 class={css({ mt: '5', fontSize: 'xl', fontWeight: 'semibold', color: 'fg.default' })}>
            {game.name}
          </h3>

          <p
            class={css({
              mt: '2',
              fontSize: 'sm',
              lineHeight: 'relaxed',
              color: 'fg.muted',
              flex: '1',
            })}
          >
            {game.description}
          </p>

          <div class={css({ mt: '6', display: 'flex', flexWrap: 'wrap', gap: '2.5' })}>
            <a href={game.releases}>
              <Button>
                <Download size={17} />
                Download
              </Button>
            </a>
            <a href={game.repo}>
              <Button variant="outline" colorPalette="gray">
                <GithubIcon size={16} />
                GitHub
              </Button>
            </a>
          </div>
        </div>
      ))
    }
  </div>
</Section>
