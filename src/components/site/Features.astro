---
import { css } from 'styled-system/css'
import Section from '@/components/layout/Section.astro'
import SectionHeading from '@/components/layout/SectionHeading.astro'
import { features } from '@/data/features'
---

<Section bg="subtle">
  <SectionHeading
    title="A full modding SDK"
    subtitle="Everything you need to build script mods, from the API down to how players install them."
  />

  <div
    class={css({
      mt: '12',
      display: 'grid',
      gridTemplateColumns: { base: '1fr', md: 'repeat(3, 1fr)' },
      gap: { base: '10', md: '8' },
    })}
  >
    {
      features.map((feature) => (
        <div>
          <div
            class={css({
              display: 'grid',
              placeItems: 'center',
              w: '10',
              h: '10',
              borderRadius: 'lg',
              bg: 'gh.neutralMuted',
              color: 'gh.link',
            })}
          >
            <feature.icon size={20} />
          </div>
          <h3
            class={css({ mt: '5', fontSize: 'lg', fontWeight: 'semibold', color: 'fg.default' })}
            set:html={feature.title}
          />
          <p
            class={css({ mt: '2', fontSize: 'sm', lineHeight: 'relaxed', color: 'fg.muted' })}
            set:html={feature.body}
          />
        </div>
      ))
    }
  </div>
</Section>
